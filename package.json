{
    "name": "y-comb-workspace",
    "private": true,
    "workspaces": [
        "decision-engine"
    ],
    "scripts": {
        "dev": "npm --workspace decision-engine run dev",
        "build": "npm --workspace decision-engine run build",
        "start": "npm --workspace decision-engine run start",
        "lint": "npm --workspace decision-engine run lint",
        "typecheck": "npm --workspace decision-engine run typecheck",
        "vercel-build": "npm --workspace decision-engine run build && rm -rf .next && cp -R decision-engine/.next .next"
    },
    "dependencies": {
        "next": "16.2.4",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    }
}